---
import WebcamFrame from './WebcamFrame.astro';

type Position = 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';

interface Props {
  videos: {
    topLeft: string | undefined;
    topRight: string | undefined;
    bottomLeft: string | undefined;
    bottomRight: string | undefined;
  };
}

const { videos } = Astro.props;

const GRID_POSITIONS: readonly Position[] = ['top-left', 'top-right', 'bottom-left', 'bottom-right'];

const POSITION_TO_KEY: Record<Position, keyof typeof videos> = {
  'top-left': 'topLeft',
  'top-right': 'topRight',
  'bottom-left': 'bottomLeft',
  'bottom-right': 'bottomRight',
};

const getVideoId = (position: Position): string | undefined => videos[POSITION_TO_KEY[position]];
---

<section class="webcam-grid" aria-label="Live webcams grid">
  {GRID_POSITIONS.map(position => (
    <WebcamFrame position={position} videoId={getVideoId(position)} />
  ))}
</section>

<style>
  .webcam-grid {
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 2px;
    background-color: #2a2a2a;
  }

  @media (max-width: 768px) {
    .webcam-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(4, auto);
      height: auto;
    }
  }
</style>
