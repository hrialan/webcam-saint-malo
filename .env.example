# YouTube video IDs for the 2x2 webcam grid.
# A YouTube ID is the part after `watch?v=` in the URL.
# In production, these are injected by GitHub Actions Variables.
# For local development, copy this file to `.env.local` and fill in the IDs.

YOUTUBE_VIDEO_TOP_LEFT_ID=
YOUTUBE_VIDEO_TOP_RIGHT_ID=
YOUTUBE_VIDEO_BOTTOM_LEFT_ID=
YOUTUBE_VIDEO_BOTTOM_RIGHT_ID=
